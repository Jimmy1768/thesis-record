<h1>ThesisRecord</h1>

<%= form_with url: session_path do |form| %>
  <div>
    <%= form.label :email %>
    <%= form.email_field :email, autocomplete: "email" %>
  </div>

  <div>
    <%= form.label :password %>
    <%= form.password_field :password, autocomplete: "current-password" %>
  </div>

  <%= form.submit "Sign in" %>
<% end %>
