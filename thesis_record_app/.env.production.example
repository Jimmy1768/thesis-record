# ThesisRecord production environment template.
# Copy this on the server only and fill values outside Git.

RAILS_ENV=production
RAILS_SERVE_STATIC_FILES=true
RAILS_LOG_TO_STDOUT=true
RAILS_FORCE_SSL=false
RAILS_RELATIVE_URL_ROOT=/thesis
PORT=3400
THESIS_RECORD_BIND=127.0.0.1

# Set real values only in the server environment or managed secret store.
DATABASE_URL=
REDIS_URL=
SECRET_KEY_BASE=

# One-time bootstrap values. Do not commit real values.
THESIS_RECORD_ADMIN_EMAIL=
THESIS_RECORD_ADMIN_PASSWORD=
THESIS_RECORD_ADMIN_ROLE=research_admin
THESIS_RECORD_BOOTSTRAP_OVERRIDE=false

# Optional runtime tuning.
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2
SIDEKIQ_CONCURRENCY=5

# Optional operator alerts. Use real values only in the server environment.
THESIS_RECORD_ALERT_EMAIL_TO=
THESIS_RECORD_MAIL_FROM_NAME=ThesisRecord
THESIS_RECORD_MAIL_FROM_EMAIL=no-reply@example.invalid
BREVO_API_KEY=
BREVO_FORCE_IPV4=false
BREVO_OPEN_TIMEOUT=3
BREVO_READ_TIMEOUT=5
